---
import MainLayout from "@/layouts/MainLayout.astro";
import {
  generateBreadcrumbSchema,
  generateServiceSEO,
  generateServiceSchema,
  generateFAQSchema,
  REVIEWS_SCHEMA,
  COMPANY_INFO,
} from "@/config/seo";
import type { Service } from "@/config/services";
import { getFAQsByCategory } from "@/config/faqs";

const slugToCategory: Record<string, string> = {
  "diseno-web-estrategico": "diseno-web",
  "publicidad-digital": "publicidad-digital",
  "ecommerce": "ecommerce",
};

interface Props {
  service: Service;
}

const { service } = Astro.props;

const seo = generateServiceSEO(service);

const schema = generateServiceSchema(service);

const breadcrumbs = [
  { name: "Inicio", url: `${COMPANY_INFO.url}/` },
  { name: "Servicios", url: `${COMPANY_INFO.url}/servicios/` },
  { name: service.title, url: `${COMPANY_INFO.url}/servicios/${service.slug}/` },
];

const breadcrumbSchema = generateBreadcrumbSchema(breadcrumbs);

const serviceFaqs = getFAQsByCategory(slugToCategory[service.slug] ?? "");
const faqSchema = serviceFaqs.length ? generateFAQSchema(serviceFaqs) : null;

// Include REVIEWS_SCHEMA since all service pages display SocialProof component
const schemas = [breadcrumbSchema, schema, REVIEWS_SCHEMA, ...(faqSchema ? [faqSchema] : [])];
---

<MainLayout seoProps={seo} aditionalSchemas={schemas}>
  <slot />
</MainLayout>
