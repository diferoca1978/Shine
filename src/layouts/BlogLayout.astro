---
import MainLayout from "@/layouts/MainLayout.astro";
import {
    generateBlogSchema,
    generateBreadcrumbSchema,
    generatePageSEO,
    type JSONLDSchema,
} from "@/config/seo";

interface Props {
    title?: string;
    description: string;
    posts?: Array<{
        id: string;
        title: string;
        description: string;
        publishDate: Date;
        modifiedDate?: Date;
        tags?: string[];
        image?: string;
    }>;
}

const { title, description, posts } = Astro.props;

const blogSeoProps = generatePageSEO({
    title: title || "Blog",
    description,
    path: "/blog",
});

const aditionalSchemas: JSONLDSchema[] = [];

const breadcrumbSchema = generateBreadcrumbSchema([
    { name: "Inicio", url: "/" },
    { name: "Blog", url: "/blog" },
]);

aditionalSchemas.push(breadcrumbSchema);

if (posts && posts.length > 0) {
    aditionalSchemas.push(generateBlogSchema(posts));
}
---

<MainLayout
    seoProps={blogSeoProps}
    aditionalSchemas={aditionalSchemas}
>
    <slot />
</MainLayout>
