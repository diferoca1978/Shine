---
import { mockGoogleReviews } from "../../data/mockGoogleReviews";
import GoogleLogo from "@/assets/icons/googleLogo.svg";
import StarIcon from "@/assets/icons/star40x40.svg";
import CalendarIcon from "@/assets/icons/calendarProject.svg";
import ReviewCard from "../ui/ReviewCard.astro";
import Button from "../ui/button.astro";
import { services } from "@/config/services";
import { getCollection } from "astro:content";

const works = await getCollection("works");
const projectCount = works.length;

interface Props {
  titleLine1: string;
  titleLine2?: string;
  filterTag?: string;
  limit?: number;
}

const { titleLine1, titleLine2, filterTag, limit = 3 } = Astro.props;

const reviews = mockGoogleReviews;

const showReviews = reviews.slice(0, limit);

const filteredReviews = filterTag
  ? reviews.filter((review) => review.tag.includes(filterTag)).slice(0, limit)
  : showReviews;

const currentPath = Astro.url.pathname;
---

<section class="social-proof max-w-7xl mx-auto pb-10 lg:pb-20">
  <div class="reviews-wrapper flex flex-col items-center p-4">
    <h2
      class="section-title text-[min(10vw,42px)] text-center text-smokyBlack dark:text-softWhite leading-tight tracking-tight mb-16"
    >
      {titleLine1}
      {titleLine2 && <span class="block">{titleLine2}</span>}
    </h2>
    <!-- Reviews -->
    <div class="reviews mb-8">
      <div
        class="review-wrapper flex flex-col lg:flex-row justify-between items-center gap-6 shrink-0"
      >
        {
          filteredReviews.map((review) => (
            <ReviewCard
              reviewerLogo={review.profile_photo_url}
              reviewerName={review.author_name}
              review={review.text}
              rating={review.rating}
              tag={review.tag}
            />
          ))
        }
      </div>
    </div>
    <!-- Stats Cards -->
    <div class="stats-section w-full mx-auto">
      <div class="max-w-6xl mx-auto px-4">
        <div
          class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6 lg:gap-8"
        >
          <!-- Google Review Card -->
          <div
            class="about-stat invisible flex flex-col items-center justify-center rounded-2xl border border-smokyBlack/10 dark:border-softWhite/12 bg-softBeige dark:bg-smokyBlack p-3 shadow-sm"
          >
            <div class="flex items-center gap-3">
              <span
                class="font-playfair text-[min(14vw,72px)] leading-none font-bold text-smokyBlack dark:text-softWhite"
                aria-label="Calificación 5 estrellas"
              >
                <span class="stat-count text-deepplum dark:text-softWhite " data-count-to="5">5</span>
              </span>
              <span class="text-base flex flex-col items-center gap-2">
                ⭐⭐⭐⭐⭐
                <GoogleLogo
                  class="h-4 lg:h-5 w-auto opacity-90"
                  aria-label="Google"
                />
              </span>
            </div>
            <p
              class="text-center text-[min(3vw,13px)] leading-snug text-smokyBlack/60 dark:text-softWhite/55 max-w-28"
            >
              Calificación en Google
            </p>
          </div>

          <!-- 3 Servicios Card -->
          <div
            class="about-stat invisible flex flex-col items-center justify-center gap-2 p-3 sm:p-5 rounded-2xl border border-smokyBlack/10 dark:border-softWhite/12 bg-softBeige dark:bg-smokyBlack shadow-sm"
          >
            <div class="flex flex-col items-center justify-center gap-1">
              <h3
                class="text-[min(14vw,72px)] leading-none font-bold text-deepplum dark:text-accentGold"
                aria-label="3 servicios especializados"
              >
                <span class="stat-count" data-count-to="3">3</span>
              </h3>
              <span
                class="w-8 h-px bg-smokyBlack/20 dark:bg-softWhite/20"
                aria-hidden="true"
              >
              </span>
            </div>
            <p
              class="text-center text-[min(3vw,14px)] leading-snug text-smokyBlack/65 dark:text-softWhite/60"
            >
              Servicios especializados
            </p>
            <ul class="flex flex-col gap-1 list-disc list-inside">
              {services.map((service) => (
                <li
                  class="text-smokyBlack/65 dark:text-softWhite/60 text-sm"
                >
                  {service.title}
                </li>
              ))}
            </ul>
          </div>

          <!-- Proyectos Card -->
          <div
            class="about-stat invisible flex flex-col items-center justify-center gap-3 rounded-2xl border border-smokyBlack/10 dark:border-softWhite/12 bg-softBeige dark:bg-smokyBlack p-3 lg:p-5 shadow-sm"
          >
            <CalendarIcon
              class="h-6 w-6 sm:h-7 sm:w-7 text-deepplum dark:text-accentGold"
              aria-hidden="true"
            />
            <div class="flex items-center justify-center gap-2">
              <span
                class="font-playfair text-[min(14vw,72px)] leading-none font-bold text-smokyBlack dark:text-softWhite"
                aria-label={`${projectCount} proyectos`}
              >
                <span
                  class="stat-count text-deepplum dark:text-softWhite"
                  data-count-to={projectCount}>{projectCount}</span
                ><span class="text-deepplum dark:text-softWhite">+</span>
              </span>
              <p
                class="text-center text-[min(3vw,14px)] leading-snug text-smokyBlack/60 dark:text-softWhite/55 max-w-28"
              >
                Proyectos entregados <span class="block">2025-2026</span>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
    {
      currentPath === "/" && (
        <div class="mt-8">
          <Button href="/contacto/" variant="primary" animation={true}>
            Agenda tu Diagnóstico Estratégico <StarIcon />
          </Button>
        </div>
      )
    }
  </div>
</section>

<script>
  import { aboutStatsAnimation } from "@/utils/scripts/perPageAnimations/about/aboutStatsAnimation";
  aboutStatsAnimation();
</script>