---
import { Image } from "astro:assets";
import DiegoRocioBlack from "@/assets/images/diegoyrochiblack.webp";
import DiegoRocio from "@/assets/images/diegoyrochi.webp";
---

<section id="about" class="w-full mx-auto">
  <div id="wrapper-about" class="max-w-6xl mx-auto py-10 lg:py-20">
    <!-- Title -->
    <div id="about-title" class="flex items-center justify-center">
      <h1
        class="text-center text-[min(10vw,72px)] text-smokyBlack dark:text-softWhite"
      >
        Rocío y Diego: la estrategia de marketing y la tecnología detrás de
        Shine Agencia
      </h1>
    </div>
    <div class="about-content-wrapper mx-auto">
      <!-- our Image -->
      <div
        class="about-hero flex flex-col lg:flex-row items-center justify-between mb-8"
      >
        <div class="hero-image lg:w-1/2 relative">
          <Image
            id="diegorochiblack"
            src={DiegoRocioBlack}
            priority
            alt="Somos Rocío y Diego"
            width={600}
            height={600}
            class="w-full h-auto object-cover backdrop-opacity-100"
          />
          <Image
            id="diegorochi"
            src={DiegoRocio}
            priority
            alt="Somos Rocío y Diego"
            width={600}
            height={600}
            class="w-full h-auto object-cover absolute top-0 left-0 opacity-0 pointer-events-none"
          />
        </div>
        <div
          class="flex flex-col items-center justify-center text-center max-w-2xl lg:w-1/2"
        >
          <div class="about-content lg:max-w-prose mx-auto px-2 lg:px-4">
            <p
              class="split-text opacity-0 text-smokyBlack dark:text-softWhite text-center text-[min(10vw,18px)]"
            >
              Fundadores de Shine Agencia, con base en Bogotá y clientes en toda
              Colombia. Rocío lleva más de 10 años desarrollando estrategias de
              marketing digital. Diego construye sitios web con
              <span class="font-bold text-deepplum dark:text-accentGold italic">
                Astro Framework y tiendas online con Tienda Nube.</span
              >
              Juntos hacemos lo que pocas agencias pueden: estrategia de negocio y
              ejecución técnica en el mismo equipo, sin intermediarios. Primero entendemos
              tu negocio, después ejecutamos.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { aboutHeroAnimation } from "@/utils/scripts/perPageAnimations/about/aboutHeroAnimation";

  document.removeEventListener("DOMContentLoaded", aboutHeroAnimation);
  document.addEventListener("DOMContentLoaded", aboutHeroAnimation);
</script>
