---
import { AUTHORS } from "@/config/authors";
---

<section class="w-full mx-auto max-w-6xl py-10 lg:py-20">
  <div class="bio-container flex flex-col items-center justify-center">
    <h2
      class="bio-title text-[min(10vw,72px)] text-center lg:text-left text-smokyBlack dark:text-softWhite mb-8 lg:mb-20 tracking-tight"
    >
      Quienes Somos
    </h2>
    <div
      class="bio-layout flex flex-col-reverse lg:flex-row items-center justify-center gap-8 lg:gap-12 w-full"
    >
      <!-- Names outside the rect; hover (desktop) / tap (mobile) swaps the bio -->
      <ul class="bio-names flex flex-col gap-4 lg:gap-8 shrink-0">
        {
          AUTHORS.map((person, index) => (
            <li>
              <button
                type="button"
                data-bio-index={index}
                class={`bio-name text-center lg:text-right ${index === 0 ? "is-active" : ""}`}
              >
                <span class="bio-name-label block text-[min(7vw,24px)] text-smokyBlack dark:text-softWhite tracking-tight leading-tight">
                  {person.name}
                </span>
                <span class="bio-name-role block text-[min(5vw,15px)] text-smokyBlack/70 dark:text-softWhite/70">
                  {person.role}
                </span>
              </button>
            </li>
          ))
        }
      </ul>

      <!-- Rect with the bio descriptions stacked inside -->
      <div class="bio-wrapper lg:p-10 relative">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 720 450"
          width="720px"
          height="450px"
          class="max-w-full hidden lg:block"
        >
          <rect
            id="pathBio"
            x="20"
            y="20"
            width="680"
            height="410"
            style="fill: none; stroke-width: 0.5px; stroke: oklch(0.899 0.119 87.5);"
          ></rect>
        </svg>
        <div
          class="bio-info grid place-items-center max-w-2xl mx-auto relative lg:absolute lg:inset-0 p-4 lg:p-10"
        >
          {
            AUTHORS.map((person, index) => (
              <p
                class={`bio-desc bio-desc-${index} [grid-area:1/1] font-opensans text-center text-[min(10vw,18px)] text-smokyBlack dark:text-softWhite tracking-tight ${index === 0 ? "" : "invisible"}`}
              >
                {person.longBio ?? person.bio}
              </p>
            ))
          }
        </div>
      </div>

      
    </div>
  </div>
</section>

<style>
  .bio-name {
    cursor: pointer;
    opacity: 0.45;
    transition: opacity 0.3s ease;
  }
  .bio-name:hover,
  .bio-name:focus-visible,
  .bio-name.is-active {
    opacity: 1;
  }
</style>

<script>
  import { whoAreAnimation } from "@/utils/scripts/perPageAnimations/about/aboutWhoAreAnimation.js";
  whoAreAnimation();
</script>
