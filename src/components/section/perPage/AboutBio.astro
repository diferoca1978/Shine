---
import { AUTHORS } from "@/config/authors";
---

<section class="w-full mx-auto max-w-6xl py-10 lg:py-20">
  <div class="bio-container flex flex-col items-center justify-center">
    <h2
      class="bio-title text-[min(10vw,72px)] text-center lg:text-left text-smokyBlack dark:text-softWhite mb-8 lg:mb-20 tracking-tight"
    >
      Quienes Somos
    </h2>
    <div class="bio-container">
      <div class="bio-wrapper p-10 mx-auto relative">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 1088.167 500"
          preserveAspectRatio="none"
          class="hidden lg:block absolute top-0 left-0 w-full h-full z-0"
        >
          <path
            id="pathBio"
            class="stroke-smokyBlack dark:stroke-softWhite"
            style="fill: none; stroke-width: 5px; stroke-linecap: round;"
            d="M 1041 168.908 C 1041 168.908 1073.76 124.399 946.417 69.024 C 819.081 13.648 186.697 -1.265 89.459 69.024 C -7.778 139.312 -4.594 368.963 117.2 410.877 C 276.509 465.7 810.072 509.878 942.944 421.379 C 999.515 383.702 1036.71 138.355 881.592 97.3"
          ></path>
        </svg>
        <div
          class="bio-info p-6 flex flex-col items-center max-w-2xl mx-auto relative"
        >
          {
            AUTHORS.map((person, index) => (
              <div
                class={`bio-person bio-person-${index} ${index === 0 ? "" : "lg:absolute lg:top-0 lg:left-0 w-full p-6 lg:p-8 opacity-0"}`}
              >
                <h3 class="bio-info-title text-center lg:text-left text-[min(7vw,24px)] mb-4 text-smokyBlack dark:text-softWhite tracking-tight leading-tight">
                  <span>{person.name}</span>
                  <span class="block">{person.role}</span>
                </h3>

                <p class="bio-info-description font-opensans text-center lg:text-left text-[min(10vw,18px)] text-smokyBlack dark:text-softWhite tracking-tight lg:max-w-2xl lg:px-6">
                  {person.longBio ?? person.bio}
                </p>
              </div>
            ))
          }
        </div>
      </div>
