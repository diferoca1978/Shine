---
import MainLayout from "@/layouts/MainLayout.astro";
import { generateBreadcrumbSchema, generatePageSEO, CONTACT_PAGE_SCHEMA, COMPANY_INFO } from "@/config/seo";
import ContactForm from "@/components/section/perPage/ContactForm.astro";
import GlobalHero from "@/components/global/GlobalHero.astro";

const breadcrumbSchema = generateBreadcrumbSchema([
    { name: "Inicio", url: `${COMPANY_INFO.url}/` },
    { name: "Contacto", url: `${COMPANY_INFO.url}/contacto/` },
]);

const contactoSEO = generatePageSEO({
    title: "Contacto | Diagnóstico Digital Gratuito",
    description:
        "Contáctanos y agenda tu sesión de diagnóstico gratuita. Te ayudamos a transformar tu presencia digital con estrategia y propósito. Respuesta en 24 horas.",
    path: "/contacto",
});

---

<MainLayout seoProps={contactoSEO} aditionalSchemas={[breadcrumbSchema, CONTACT_PAGE_SCHEMA]}>
    <GlobalHero
        titleLine1="Contacto"
        subtitleBefore="Cuéntanos tu idea, solicita tu sesión de diagnóstico y da el primer paso"
        subtitleHighlight="hacia tu visibilidad digital."
    />
    <ContactForm />
</MainLayout>
