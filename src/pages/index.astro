---
import MainLayout from "@/layouts/MainLayout.astro";
import GlobalHero from "@/components/global/GlobalHero.astro";
import ClientHurts from "@/components/section/landing/ClientHurts.astro";
import Solution from "@/components/section/landing/Solution.astro";
import ServicesLanding from "@/components/section/landing/ServicesLanding.astro";
import LatestProjects2 from "@/components/section/landing/LatestProjects.2.astro";
import CTABanner from "@/components/ui/CTABanner.astro";
import Button from "@/components/ui/button.astro";
import StarIcon from "@/assets/icons/star40x40.svg";
import SocialProof from "@/components/global/SocialProof.astro";
import FAQ from "@/components/section/FAQ.astro";
import { generalFAQs } from "@/config/faqs";
import {
  REVIEWS_SCHEMA,
  generatePageSEO,
  generateBreadcrumbSchema,
  generateFAQSchema,
  COMPANY_INFO,
} from "@/config/seo";

const homeSEO = generatePageSEO({
  title: "Agencia de Marketing Digital y Diseño Web",
  description:
    "Diseño web con Astro, Google Ads, Facebook Ads y ecommerce con Tienda Nube para empresas en Colombia. Bogotá. Agenda tu diagnóstico gratuito hoy.",
  path: "/",
  image: "/images/shine-og-image.png",
});

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: "Inicio", url: COMPANY_INFO.url },
]);

const faqSchema = generateFAQSchema(generalFAQs);
---

<MainLayout
  seoProps={homeSEO}
  aditionalSchemas={[REVIEWS_SCHEMA, breadcrumbSchema, faqSchema]}
>
  <GlobalHero
    titleLine1="Diseño web, publicidad digital y"
    titleLine2="e-commerce para negocios que quieren vender más"
    subtitleBefore="Construimos sitios con Astro Framework que cargan en menos de 1 segundo, gestionamos"
    subtitleHighlight="campañas en Google y Meta"
    subtitleAfter="y creamos tiendas online."
    descriptionLine1="" 
    descriptionLine2=""
  >
    <Button slot="cta" href="/contacto/" variant="primary" animation={true}>
      Agenda tu Diagnóstico Estratégico <StarIcon />
    </Button>
  </GlobalHero>
  <Solution />
  <ClientHurts />
  <ServicesLanding />
  <SocialProof
    titleLine1="Historias de éxito"
    titleLine2="Así brillan nuestros aliados estratégicos"
    filterTag="all"
  />
  <LatestProjects2 />

  <FAQ
    faqs={generalFAQs}
    title="Preguntas frecuentes"
    subtitle="Todo lo que necesitas saber antes de empezar"
  />

  <div class="px-2 mt-8">
    <CTABanner
      title="¿Listo para que tu negocio empiece a vender más?"
      description="El diagnóstico es gratuito y dura 30 minutos. Sin compromiso. Sin venta a presión."
      buttonText="Agenda tu Diagnóstico Estratégico"
      buttonHref="/contacto/"
      variant="default"
      className="max-w-6xl mx-auto"
    />
  </div>
</MainLayout>
