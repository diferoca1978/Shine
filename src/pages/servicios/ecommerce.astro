---
import ServiceLayout from "@/layouts/ServiceLayout.astro";
import { getServiceBySlug } from "@/config/services";
import CTABanner from "@/components/ui/CTABanner.astro";
import GlobalHero from "@/components/global/GlobalHero.astro";
import Button from "@/components/ui/button.astro";
import StarIcon from "@/assets/icons/star40x40.svg";
import ServicesStepsProcess from "@/components/section/ourServices/ServicesStepsProcess.astro";
import ServiceProblemSection from "@/components/section/ourServices/ServiceProblemSection.astro";
import ServiceSolutionSection from "@/components/section/ourServices/ServiceSolutionSection.astro";
import EcommerceComparisonTable from "@/components/section/ourServices/EcommerceComparisonTable.astro";
import SocialProof from "@/components/global/SocialProof.astro";
import FAQ from "@/components/section/FAQ.astro";
import { ecommerceFAQs } from "@/config/faqs";

const service = getServiceBySlug("ecommerce");

if (!service) {
  return Astro.redirect("/404");
}
---

<ServiceLayout service={service}>
  <!-- Hero -->
  <GlobalHero
    titleLine1="Tu negocio ya está listo"
    titleLine2="para vender por internet"
    subtitleBefore="Creamos tu tienda online con Tienda Nube:"
    subtitleHighlight="diseño personalizado, medios de pago colombianos"
    subtitleAfter="y lista para vender desde el primer día"
    descriptionLine1="Pasá de vender por WhatsApp e Instagram a tener tu propia tienda online profesional."
    descriptionLine2="Sin depender de intermediarios. Con el control total de tu negocio."
  >
    <Button
      slot="cta"
      href="/contacto/"
      variant="primary"
      animation={true}
      className="w-fit mx-auto"
    >
      Agenda tu diagnóstico de ecommerce gratuito <StarIcon />
    </Button>
  </GlobalHero>
  <!-- Problem -->
  <ServiceProblemSection
    title={service.problem!}
    image={service.secondaryImage}
    imageAlt={service.alt}
    introText={service.introText!}
    problems={service.hurts!}
    imagePosition="right"
  />
  <!-- Solution -->
  <ServiceSolutionSection
    benefitsTitle={service.benefitsTitle!}
    benefitsIntro={service.benefitsIntro!}
    benefits={service.benefits!}
    audienceTitle={service.audienceTitle!}
    audienceIntro={service.audienceIntro!}
    checkmarks={service.checkMarks!}
  />

  <EcommerceComparisonTable />

  <!-- Our process -->
  <ServicesStepsProcess
    titleLine1="De cero a tu tienda"
    titleLine2="lista para vender"
    service={service}
  />
  <!-- Social proof -->
  <SocialProof
    titleLine1="La voz de quienes ya confiaron en Shine"
    titleLine2="para su tienda online"
    filterTag="all"
  />
  <!-- FAQ -->
  <FAQ faqs={ecommerceFAQs} />
  <!-- CTA -->
  <div class="px-2">
    <CTABanner
      title="¿Listo para vender online sin depender de nadie?"
      description="Tu tienda online puede estar lista en menos de 4 semanas. Empieza con un diagnóstico gratuito — sin compromiso. Sin complicaciones. Con acompañamiento real."
      buttonText="Agenda tu diagnóstico de ecommerce gratuito"
      buttonHref="/contacto/"
      variant="default"
      className="max-w-6xl mx-auto"
    />
  </div>
</ServiceLayout>
