---
import ServiceLayout from "@/layouts/ServiceLayout.astro";
import { getServiceBySlug } from "@/config/services";
import CTABanner from "@/components/ui/CTABanner.astro";
import GlobalHero from "@/components/global/GlobalHero.astro";
import Button from "@/components/ui/button.astro";
import StarIcon from "@/assets/icons/star40x40.svg";
import ServicesStepsProcess from "@/components/section/ourServices/ServicesStepsProcess.astro";
import ServiceProblemSection from "@/components/section/ourServices/ServiceProblemSection.astro";
import ServiceSolutionSection from "@/components/section/ourServices/ServiceSolutionSection.astro";
import AdsComparisonTable from "@/components/section/ourServices/AdsComparisonTable.astro";
import SocialProof from "@/components/global/SocialProof.astro";
import FAQ from "@/components/section/FAQ.astro";
import { publicidadDigitalFAQs } from "@/config/faqs";

const service = getServiceBySlug("publicidad-digital");

if (!service) {
  return Astro.redirect("/404");
}
---

<ServiceLayout service={service}>
  <!-- Hero -->
  <GlobalHero
    titleLine1="Deja de invertir en pauta"
    titleLine2="y no saber si funciona"
    subtitleBefore="Gestionamos tus campañas en Google Ads y Facebook Ads para que"
    subtitleHighlight="cada peso invertido"
    subtitleAfter="traiga clientes reales, no solo clics"
    descriptionLine1="Diseñamos, configuramos y optimizamos campañas publicitarias en Google y Meta"
    descriptionLine2="para empresas y emprendedores en Colombia que quieren resultados medibles."
  >
    <Button
      slot="cta"
      href="/contacto/"
      variant="primary"
      animation={true}
      className="w-fit mx-auto"
    >
      Agenda tu diagnóstico de pauta gratuito <StarIcon />
    </Button>
  </GlobalHero>
  <!-- Problem -->
  <ServiceProblemSection
    title={service.problem!}
    image={service.secondaryImage}
    imageAlt={service.alt}
    introText={service.introText!}
    problems={service.hurts!}
    imagePosition="right"
  />
  <!-- Solution -->
  <ServiceSolutionSection
    benefitsTitle={service.benefitsTitle!}
    benefitsIntro={service.benefitsIntro!}
    benefits={service.benefits!}
    audienceTitle={service.audienceTitle!}
    audienceIntro={service.audienceIntro!}
    checkmarks={service.checkMarks!}
  />

  <AdsComparisonTable />

  <!-- Our process -->
  <ServicesStepsProcess
    titleLine1="Así gestionamos"
    titleLine2="tus campañas"
    service={service}
  />
  <!-- Social proof -->
  <SocialProof
    titleLine1="La voz de quienes ya confiaron en Shine"
    titleLine2="para su publicidad digital"
    filterTag="all"
  />
  <!-- FAQ -->
  <FAQ faqs={publicidadDigitalFAQs} />
  <!-- CTA -->
  <div class="px-2">
    <CTABanner
      title="¿Listo para que tu pauta empiece a trabajar de verdad?"
      description="Todavía estás a tiempo de convertir tu presupuesto publicitario en clientes reales. El primer paso es entender qué está fallando — y eso lo hacemos gratis."
      buttonText="Agenda tu diagnóstico de pauta gratuito"
      buttonHref="/contacto/"
      variant="default"
      className="max-w-6xl mx-auto"
    />
  </div>
</ServiceLayout>
