---
import { getServiceBySlug } from "@/config/services";
import { disenoWebFAQs } from "@/config/faqs";
import ServiceLayout from "@/layouts/ServiceLayout.astro";
import CTABanner from "@/components/ui/CTABanner.astro";
import GlobalHero from "@/components/global/GlobalHero.astro";
import Button from "@/components/ui/button.astro";
import StarIcon from "@/assets/icons/star40x40.svg";
import ServicesStepsProcess from "@/components/section/ourServices/ServicesStepsProcess.astro";
import ProcessSteps from "@/components/section/ourServices/ProcessSteps.astro";
import ServiceProblemSection from "@/components/section/ourServices/ServiceProblemSection.astro";
import ServiceSolutionSection from "@/components/section/ourServices/ServiceSolutionSection.astro";
import AstroVsWordpressTable from "@/components/section/ourServices/AstroVsWordpressTable.astro";
import SocialProof from "@/components/global/SocialProof.astro";
import FAQ from "@/components/section/FAQ.astro";

const service = getServiceBySlug("diseno-web-estrategico");

if (!service) {
  return Astro.redirect("/404");
}
---

<ServiceLayout service={service}>
  <!-- Hero -->
  <GlobalHero
    titleLine1="Diseño web con Astro en Colombia:"
    titleLine2="sitios que cargan en menos de 1 segundo"
    subtitleBefore="Construimos tu sitio web desde cero con Astro Framework —"
    subtitleHighlight="la tecnología que supera a WordPress"
    subtitleAfter="en velocidad, seguridad y posicionamiento en Google."
    descriptionLine1="Creamos sitios web ultrarrápidos, seguros y optimizados para empresas y emprendedores"
    descriptionLine2="en Colombia que necesitan una presencia digital que sí vende."
  >
    <Button
      slot="cta"
      href="/contacto/"
      variant="primary"
      animation={true}
      className="w-fit mx-auto"
    >
      Agenda tu Diagnóstico Web Gratuito <StarIcon />
    </Button>
  </GlobalHero>
  <!-- Problem -->
  <ServiceProblemSection
    title={service.problem!}
    image={service.secondaryImage}
    imageAlt={service.alt}
    introText={service.introText!}
    problems={service.hurts!}
    imagePosition="right"
  />
  <!-- Solution -->
  <ServiceSolutionSection
    benefitsTitle={service.benefitsTitle!}
    benefitsIntro={service.benefitsIntro!}
    benefits={service.benefits!}
    audienceTitle={service.audienceTitle!}
    audienceIntro={service.audienceIntro!}
    checkmarks={service.checkMarks!}
  />

  <AstroVsWordpressTable />

  <!-- Our process -->
  <!-- <ServicesStepsProcess
    titleLine1="De la primera llamada a tu sitio web en vivo:"
    titleLine2="así funciona trabajar con Shine"
    service={service}
  /> -->
  <ProcessSteps service={service} />

  <!-- Social proof -->
  <SocialProof
    titleLine1="La voz de quienes ya confiaron en Shine"
    titleLine2="para su presencia digital"
    filterTag="diseño web"
  />

  <!-- FAQ -->
  <FAQ faqs={disenoWebFAQs} />
  <!-- CTA -->
  <div class="px-2">
    <CTABanner
      title="Tu sitio web puede estar listo en 2 semanas"
      description="Sin WordPress. Sin plugins que se rompen. El diagnóstico es gratuito y dura 30 minutos. Sales de la llamada sabiendo exactamente qué necesitas."
      buttonText="Agenda tu Diagnóstico Web Gratuito"
      buttonHref="/contacto/"
      variant="default"
      className="max-w-6xl mx-auto"
    />
  </div>
</ServiceLayout>
