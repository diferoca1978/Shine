---
import MainLayout from "@/layouts/MainLayout.astro";
import HeroAbout from "@/components/section/perPage/HeroAbout.astro";
import AboutFoundationsAlt from "@/components/section/perPage/AboutFoundationsAlt.astro";
import AboutMission from "@/components/section/perPage/AboutMission.astro";
import AboutStats from "@/components/section/perPage/AboutStats.astro";
import AboutBio from "@/components/section/perPage/AboutBio.astro";
import CTABanner from "@/components/ui/CTABanner.astro";
import {
  generateBreadcrumbSchema,
  generatePageSEO,
  generateAllAuthorsSchemas,
  COMPANY_INFO,
} from "@/config/seo";


const breadcrumbSchema = generateBreadcrumbSchema([
  { name: "Inicio", url: `${COMPANY_INFO.url}/` },
  { name: "Nosotros", url: `${COMPANY_INFO.url}/nosotros/` },
]);

const authorSchemas = generateAllAuthorsSchemas();

const nosotrosSEO = generatePageSEO({
  title: "Rocío Parra y Diego Rodríguez | Equipo Shine Agencia Colombia",
  description:
    "Conoce a Rocío y Diego, el equipo detrás de Shine Agencia: más de 10 años en marketing digital, desarrollo web con Astro y ecommerce con Tienda Nube en Colombia.",
  path: "/nosotros",
});
---

<MainLayout
  seoProps={nosotrosSEO}
  aditionalSchemas={[breadcrumbSchema, ...authorSchemas]}
>
  <HeroAbout />
  <AboutMission />
  <AboutStats />
  <AboutFoundationsAlt />
  <AboutBio />
  <CTABanner
    title="Listo para brillar con Propósito?"
    description="Descubre cómo Shine puede ayudarte a crecer con autenticidad."
    buttonText="Agenda tu diagnóstico estratégico"
    buttonHref="/contacto/"
    variant="default"
    className="max-w-6xl mx-auto"
  />
</MainLayout>
